# ── Supabase ──────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # NEVER expose to client

# ── Resend (transactional email) ──────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=Think in Products <hello@thinkinproducts.com>
# Webhook secret — copy from Resend Dashboard → Webhooks → Signing Secret
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3001   # Use https://thinkinproducts.com in prod
ADMIN_EMAIL=madan@accessionhealthtech.com
